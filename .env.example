# Copy this file to .env and fill in your IDs.
# These move to server-side env vars once a backend is added.

# Amazon Associates tracking tag (e.g. dejabuy-20)
AMAZON_ASSOCIATE_TAG=

# eBay Partner Network campaign ID and custom tracking ID
EBAY_CAMPAIGN_ID=
EBAY_CUSTOM_ID=dejabuy

# Back Market affiliate ID (via Impact)
BACKMARKET_AFFILIATE_ID=

# Rakuten publisher ID (covers Newegg and others)
RAKUTEN_PUBLISHER_ID=

# Reebelo affiliate ID (via CJ Affiliate or direct)
REEBELO_AFFILIATE_ID=
