# Kopieren Sie diese Datei als .env und tragen Sie Ihre IDs ein.
# (Copy this file to .env and fill in your IDs.)
# Diese werden zu serverseitigen Umgebungsvariablen, sobald ein Backend hinzugefügt wird.
# Amazon.de Associates Tracking-Tag (z.B. dejabuy-de-21)
AMAZON_DE_ASSOCIATE_TAG=
# eBay.de Partner Network Kampagnen-ID und Tracking-ID
EBAY_DE_CAMPAIGN_ID=
EBAY_DE_CUSTOM_ID=dejabuy
# Back Market Affiliate-ID (via Awin / Affiliate Window)
BACKMARKET_AWIN_AFFILIATE_ID=
# Rebuy.de Affiliate-ID (via ADCELL)
REBUY_ADCELL_AFFILIATE_ID=
# Refurbed.com Affiliate-ID (Direktprogramm via impact.com)
REFURBED_AFFILIATE_ID=
# Asgoodasnew.com Affiliate-ID (via Awin / Affiliate Window)
ASGOODASNEW_AWIN_AFFILIATE_ID=
